{
  "manifest_version": 3,
  "name": "Menu Extension",
  "version": "0.2",
  "description": "Opens a generated page on command",
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "open-menu": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Open the menu page"
    }
  },
  "content_scripts": [
    {
      "matches": ["file:///*menu_extension_menu_page.html"],
      "js": ["content.js"]
    }
  ],
  "permissions": ["tabs", "windows"]
}
